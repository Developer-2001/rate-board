{
  "name": "rate-board",
  "version": "0.1.0",
  "description": "Paras Infotech Rate Board desktop and mobile app bundle",
  "author": "Paras Infotech",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "concurrently -k \"next dev\" \"wait-on tcp:3000 && cross-env ELECTRON_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "build": "next build",
    "build:web": "next build",
    "build:static": "node scripts/build-static.mjs",
    "build:desktop": "npm run build:static && electron-builder --win nsis",
    "build:android": "npm run build:static && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "start": "next start",
    "start:static": "serve out",
    "lint": "eslint"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "crypto-js": "^4.2.0",
    "lucide-react": "^1.3.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@capacitor/cli": "^7.4.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.parasinfotech.rateboard",
    "productName": "Rate Board",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "src/app/favicon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
